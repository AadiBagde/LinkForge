# LinkForge Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=LinkForge
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Database (PostgreSQL recommended for production)
# Local development: MySQL
DATABASE_URL=mysql+pymysql://root:rootpassword@localhost:3306/urlshortener
# Production: PostgreSQL via Neon
# DATABASE_URL=postgresql://user:password@db.neon.tech/dbname

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=None
# Production: Upstash Redis
# REDIS_HOST=your-instance.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=10
RATE_LIMIT_WINDOW=60

# Caching
CACHE_EXPIRY=3600

# Base URL
# Local development
BASE_URL=http://localhost:8000
# Production
# BASE_URL=https://linkforge.onrender.com

# CORS
CORS_ORIGINS=["*"]

# External Services
# IP Geolocation API
GEOLOCATION_API=ip-api.com
# Optional: Add API key if using paid tier
GEOLOCATION_API_KEY=None
